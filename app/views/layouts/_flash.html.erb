<% if alert = flash[:alert] %>
  <div class="mb-6 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700" id="alert"><%= alert %></div>
<% end %>
<% if notice = flash[:notice] %>
  <div class="mb-6 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700" id="notice"><%= notice %></div>
<% end %>
