<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Affiliate orders</h1>
    <p class="mt-1 text-sm text-gray-500">Orders attributed to your affiliate creators, synced from <code>Search Seller Affiliate Orders</code>.</p>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-lg border border-gray-200 bg-white p-5">
      <dt class="text-xs uppercase tracking-wide text-gray-500">Orders shown</dt>
      <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @totals[:count] %></dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-5">
      <dt class="text-xs uppercase tracking-wide text-gray-500">GMV</dt>
      <dd class="mt-1 text-2xl font-semibold text-emerald-700">$<%= number_with_delimiter((@totals[:gmv_cents] / 100.0).round) %></dd>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-5">
      <dt class="text-xs uppercase tracking-wide text-gray-500">Commission paid</dt>
      <dd class="mt-1 text-2xl font-semibold text-gray-900">$<%= number_with_delimiter((@totals[:commission_cents] / 100.0).round) %></dd>
    </div>
  </div>

  <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
        <tr>
          <th class="px-4 py-3">Date</th>
          <th class="px-4 py-3">Creator</th>
          <th class="px-4 py-3">Campaign</th>
          <th class="px-4 py-3">Product</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3 text-right">GMV</th>
          <th class="px-4 py-3 text-right">Commission</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @orders.each do |o| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500 whitespace-nowrap"><%= o.ordered_at&.strftime("%b %-d, %Y") %></td>
            <td class="px-4 py-3">
              <% if o.creator %>
                <%= link_to "@#{o.creator.handle}", shop_creator_path(o.creator), class: "text-gray-900 hover:text-indigo-600" %>
              <% else %>—<% end %>
            </td>
            <td class="px-4 py-3 text-gray-700 truncate max-w-[200px]">
              <% if o.campaign %><%= link_to o.campaign.name, shop_campaign_path(o.campaign), class: "hover:text-indigo-600" %><% else %>—<% end %>
            </td>
            <td class="px-4 py-3 text-gray-700 truncate max-w-[180px]"><%= o.product&.name || "—" %></td>
            <td class="px-4 py-3">
              <% colors = { "pending" => "bg-gray-100 text-gray-700", "confirmed" => "bg-indigo-100 text-indigo-700", "settled" => "bg-emerald-100 text-emerald-700", "cancelled" => "bg-red-100 text-red-700", "refunded" => "bg-amber-100 text-amber-700" } %>
              <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= colors[o.order_status] %>"><%= o.order_status %></span>
            </td>
            <td class="px-4 py-3 text-right tabular-nums font-semibold text-emerald-700">$<%= sprintf("%.2f", o.gmv_dollars) %></td>
            <td class="px-4 py-3 text-right tabular-nums text-gray-900">$<%= sprintf("%.2f", o.commission_dollars) %></td>
          </tr>
        <% end %>
        <% if @orders.empty? %>
          <tr><td colspan="7" class="px-4 py-12 text-center text-gray-500">No affiliate orders yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
