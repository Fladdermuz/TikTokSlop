<%= form_with model: product, url: (product.persisted? ? shop_product_path(product) : shop_products_path), class: "space-y-4 rounded-lg border border-gray-200 bg-white p-6" do |f| %>
  <% if product.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <%= product.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, required: true, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :external_id, "TikTok Shop product SKU (optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :external_id, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :image_url, "Image URL (optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :image_url, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :price_dollars, "Price ($)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :price_dollars, step: 0.01, min: 0, value: product.price_dollars,
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :status, Product::STATUSES.map { |s| [ s.capitalize, s ] }, {}, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
  </div>

  <div class="flex items-center justify-between border-t border-gray-100 pt-4">
    <%= link_to "Cancel", shop_products_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= f.submit (product.persisted? ? "Save" : "Add product"), class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  </div>
<% end %>
