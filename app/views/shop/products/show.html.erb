<div class="mx-auto max-w-3xl space-y-6">
  <div>
    <%= link_to "← Back to products", shop_products_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <div class="flex items-start justify-between">
      <div class="flex items-start gap-4">
        <% if @product.image_url.present? %>
          <img src="<%= @product.image_url %>" alt="" class="h-20 w-20 rounded-md object-cover bg-gray-100">
        <% end %>
        <div>
          <h1 class="text-2xl font-semibold text-gray-900"><%= @product.name %></h1>
          <p class="mt-1 text-sm text-gray-500">$<%= format("%.2f", @product.price_dollars) %> · <span class="capitalize"><%= @product.status %></span></p>
          <% if @product.external_id.present? %>
            <p class="mt-1 font-mono text-xs text-gray-400">SKU: <%= @product.external_id %></p>
          <% end %>
        </div>
      </div>
      <div class="flex gap-2">
        <%= link_to "Knowledge base", shop_product_knowledge_path(@product), class: "rounded-md border border-emerald-300 bg-white px-3 py-2 text-sm font-medium text-emerald-700 hover:bg-emerald-50" %>
        <% if policy_for(@product).update? %>
          <%= link_to "Edit", edit_shop_product_path(@product), class: "rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-base font-semibold text-gray-900">Used in campaigns</h2>
    <% campaigns = @product.campaigns.order(created_at: :desc) %>
    <% if campaigns.any? %>
      <ul class="mt-3 divide-y divide-gray-100">
        <% campaigns.each do |c| %>
          <li class="flex items-center justify-between py-2">
            <%= link_to c.name, shop_campaign_path(c), class: "text-sm text-gray-900 hover:text-indigo-600" %>
            <span class="text-xs capitalize text-gray-500"><%= c.status %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-2 text-sm text-gray-500">Not used in any campaigns yet.</p>
    <% end %>
  </div>
</div>
