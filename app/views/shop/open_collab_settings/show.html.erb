<div class="mx-auto max-w-2xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Open Collaboration settings</h1>
    <p class="mt-1 text-sm text-gray-500">Shop-wide controls for how your product catalog participates in TikTok's Creator Marketplace open collaboration plan.</p>
  </div>

  <%= form_with model: @shop, url: shop_open_collab_settings_path, method: :patch, class: "space-y-5 rounded-lg border border-gray-200 bg-white p-6" do |f| %>
    <% if @shop.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <%= @shop.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="flex items-start gap-3">
      <%= f.check_box :open_collab_auto_add, class: "mt-1 rounded border-gray-300 text-indigo-600" %>
      <div>
        <%= f.label :open_collab_auto_add, "Auto-enroll new products", class: "block text-sm font-medium text-gray-900" %>
        <p class="mt-0.5 text-xs text-gray-500">When enabled, any new product you add to this shop will be automatically enrolled in your open collaboration plan. Default off per TikTok policy.</p>
      </div>
    </div>

    <div>
      <%= f.label :open_collab_default_commission_rate, "Default commission rate (0.0–1.0)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :open_collab_default_commission_rate, step: 0.01, min: 0, max: 1,
            class: "mt-1 block w-48 rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      <p class="mt-1 text-xs text-gray-500">Applied to auto-enrolled products unless overridden per-campaign. e.g. 0.15 = 15%.</p>
    </div>

    <div class="border-t border-gray-100 pt-4">
      <%= f.submit "Save and push to TikTok", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer" %>
      <p class="mt-2 text-xs text-gray-500">Saving calls TikTok's Edit Open Collaboration Settings API.</p>
    </div>
  <% end %>
</div>
