<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Invites</h1>
    <p class="mt-1 text-sm text-gray-500">All outreach invites sent from <%= Current.shop.name %>.</p>
  </div>

  <div class="flex gap-3">
    <%= link_to "All", shop_invites_path, class: "rounded-md px-3 py-1.5 text-sm #{params[:status].blank? ? 'bg-indigo-100 text-indigo-700 font-medium' : 'text-gray-600 hover:bg-gray-100'}" %>
    <% %w[pending sending sent accepted declined failed].each do |s| %>
      <%= link_to s.capitalize, shop_invites_path(status: s), class: "rounded-md px-3 py-1.5 text-sm #{params[:status] == s ? 'bg-indigo-100 text-indigo-700 font-medium' : 'text-gray-600 hover:bg-gray-100'}" %>
    <% end %>
  </div>

  <% if @invites.any? %>
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Creator</th>
            <th class="px-4 py-3">Campaign</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Sent</th>
            <th class="px-4 py-3">Error</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @invites.each do |inv| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <%= link_to "@#{inv.creator.handle}", shop_creator_path(inv.creator), class: "text-gray-900 hover:text-indigo-600" %>
              </td>
              <td class="px-4 py-3 text-gray-700"><%= inv.campaign.name %></td>
              <td class="px-4 py-3">
                <% colors = { "pending" => "bg-gray-100 text-gray-700", "sending" => "bg-blue-100 text-blue-700", "sent" => "bg-indigo-100 text-indigo-700", "accepted" => "bg-emerald-100 text-emerald-700", "declined" => "bg-red-100 text-red-700", "expired" => "bg-gray-200 text-gray-500", "failed" => "bg-red-100 text-red-700" } %>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= colors[inv.status] || 'bg-gray-100' %>"><%= inv.status %></span>
              </td>
              <td class="px-4 py-3 text-gray-500"><%= inv.sent_at&.strftime("%b %-d, %l:%M%P") || "—" %></td>
              <td class="px-4 py-3 text-xs text-red-600 max-w-xs truncate"><%= inv.error_message %></td>
              <td class="px-4 py-3">
                <%= link_to "View", shop_invite_path(inv), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
      <p class="text-sm text-gray-500">No invites yet. Go to Creators → select creators → Invite to campaign.</p>
    </div>
  <% end %>
</div>
