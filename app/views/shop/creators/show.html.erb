<div class="space-y-6">
  <div>
    <%= link_to "← Back to creators", shop_creators_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <div class="flex items-start gap-6">
      <% if @creator.avatar_url.present? %>
        <img src="<%= @creator.avatar_url %>" alt="" class="h-20 w-20 rounded-full bg-gray-100">
      <% end %>
      <div class="flex-1">
        <h1 class="text-2xl font-semibold text-gray-900"><%= @creator.display_name || @creator.handle %></h1>
        <p class="mt-1 text-sm text-gray-500">@<%= @creator.handle %> · <%= @creator.country %></p>
        <div class="mt-3 flex flex-wrap gap-2">
          <% Array(@creator.categories).each do |cat| %>
            <span class="rounded bg-indigo-50 px-2 py-0.5 text-xs text-indigo-700"><%= cat %></span>
          <% end %>
        </div>
      </div>
    </div>

    <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-3 sm:grid-cols-4 text-sm">
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">GMV (30d)</dt>
        <dd class="mt-1 text-lg font-semibold text-gray-900">$<%= number_with_delimiter(@creator.gmv_dollars.to_i) %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Tier</dt>
        <dd class="mt-1 text-lg font-semibold text-gray-900"><%= @creator.gmv_tier&.tr("_", " ")&.titleize %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Followers</dt>
        <dd class="mt-1 text-lg font-semibold text-gray-900"><%= number_with_delimiter(@creator.follower_count) %></dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Engagement</dt>
        <dd class="mt-1 text-lg font-semibold text-gray-900"><%= number_to_percentage((@creator.engagement_rate || 0) * 100, precision: 1) %></dd>
      </div>
    </dl>
  </div>

  <%# Showcase & Brand History %>
  <% if @creator.showcase_products.any? || @creator.brand_partnerships.any? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Showcase &amp; Brand History</h2>
      <p class="mt-1 text-sm text-gray-500">Products this creator currently promotes and past brand partnerships.</p>

      <%# Showcase Products grid %>
      <% if @creator.showcase_products.any? %>
        <h3 class="mt-5 text-sm font-medium text-gray-700">Showcase Products</h3>
        <div class="mt-3 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
          <% @creator.showcase_products.each do |product| %>
            <div class="group rounded-lg border border-gray-100 bg-gray-50 p-3 hover:border-indigo-200 hover:bg-indigo-50 transition-colors">
              <div class="aspect-square overflow-hidden rounded-md bg-white">
                <img
                  src="<%= product["image_url"] %>"
                  alt="<%= product["name"] %>"
                  class="h-full w-full object-cover"
                  onerror="this.src='https://placehold.co/200x200/f3f4f6/9ca3af?text=Product'"
                >
              </div>
              <div class="mt-2">
                <p class="truncate text-xs font-medium text-gray-800"><%= product["name"] %></p>
                <p class="mt-0.5 text-xs text-indigo-600 font-semibold">$<%= sprintf("%.2f", product["price"].to_f) %></p>
                <% if product["category"].present? %>
                  <span class="mt-1 inline-block rounded bg-gray-100 px-1.5 py-0.5 text-[10px] text-gray-500"><%= product["category"] %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Brand Partnerships %>
      <% if @creator.brand_partnerships.any? %>
        <h3 class="mt-6 text-sm font-medium text-gray-700">Brand Partnerships</h3>
        <div class="mt-3 flex flex-wrap gap-2">
          <% @creator.brand_partnerships.each do |brand| %>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-gray-200 bg-white px-3 py-1 text-sm text-gray-700 shadow-sm">
              <span class="h-2 w-2 rounded-full bg-indigo-400"></span>
              <%= brand %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Affiliate Collaboration History %>
  <% if Array(@creator.collaboration_history).any? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Affiliate Collaboration History</h2>
      <p class="mt-1 text-sm text-gray-500">Past and active affiliate collaborations this creator has participated in across TikTok Shop sellers.</p>

      <div class="mt-4 overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="text-left text-xs uppercase tracking-wide text-gray-500 border-b border-gray-100">
            <tr>
              <th class="pb-2 pr-4">Seller / Brand</th>
              <th class="pb-2 pr-4">Product</th>
              <th class="pb-2 pr-4">Commission</th>
              <th class="pb-2 pr-4">Status</th>
              <th class="pb-2 pr-4">Date Range</th>
              <th class="pb-2">Content Views</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% Array(@creator.collaboration_history).each do |collab| %>
              <tr>
                <td class="py-3 pr-4 font-medium text-gray-800"><%= collab["seller_name"] %></td>
                <td class="py-3 pr-4 text-gray-700 max-w-[200px]">
                  <span class="block truncate"><%= collab["product_name"] %></span>
                </td>
                <td class="py-3 pr-4 font-semibold text-indigo-600"><%= collab["commission_rate"] %>%</td>
                <td class="py-3 pr-4">
                  <% status = collab["status"] %>
                  <% badge_class = case status
                    when "active"    then "bg-green-50 text-green-700 ring-green-600/20"
                    when "completed" then "bg-gray-100 text-gray-600 ring-gray-500/20"
                    when "expired"   then "bg-yellow-50 text-yellow-700 ring-yellow-600/20"
                    else                  "bg-gray-100 text-gray-600 ring-gray-500/20"
                    end %>
                  <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= badge_class %>">
                    <%= status&.capitalize %>
                  </span>
                </td>
                <td class="py-3 pr-4 text-gray-500 whitespace-nowrap">
                  <% start_d = collab["start_date"]
                     end_d   = collab["end_date"] %>
                  <% if start_d.present? %>
                    <%= Date.parse(start_d.to_s).strftime("%b %-d, %Y") rescue start_d %>
                    <% if end_d.present? %>
                      &ndash; <%= Date.parse(end_d.to_s).strftime("%b %-d, %Y") rescue end_d %>
                    <% end %>
                  <% else %>
                    &mdash;
                  <% end %>
                </td>
                <td class="py-3 text-gray-700">
                  <% views = collab["content_views"].to_i %>
                  <% if views >= 1_000_000 %>
                    <%= number_with_precision(views.to_f / 1_000_000, precision: 1) %>M
                  <% elsif views >= 1_000 %>
                    <%= number_with_precision(views.to_f / 1_000, precision: 1) %>K
                  <% else %>
                    <%= views %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# Recent Sample Activity %>
  <% if Array(@creator.recent_sample_requests).any? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Recent Sample Activity</h2>
      <p class="mt-1 text-sm text-gray-500">Products this creator has recently requested samples for from other sellers — a signal of active category interest.</p>
      <ul class="mt-4 divide-y divide-gray-100">
        <% Array(@creator.recent_sample_requests).each do |req| %>
          <li class="flex items-center justify-between py-3">
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-medium text-gray-900"><%= req["product_name"] %></p>
              <p class="mt-0.5 text-xs text-gray-500"><%= req["seller_name"] %> &middot; Requested <%= req["request_date"] %></p>
            </div>
            <% status = req["status"]
               badge = case status
                 when "approved"  then "bg-blue-50 text-blue-700 ring-blue-600/20"
                 when "received"  then "bg-emerald-50 text-emerald-700 ring-emerald-600/20"
                 when "pending"   then "bg-yellow-50 text-yellow-700 ring-yellow-600/20"
                 else                  "bg-gray-100 text-gray-600 ring-gray-500/20"
               end %>
            <span class="ml-4 inline-flex shrink-0 items-center rounded-md px-2 py-0.5 text-xs font-medium ring-1 ring-inset <%= badge %>">
              <%= status&.capitalize %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Recommended Products %>
  <% if Array(@creator.recommended_products).any? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Recommended Products</h2>
      <p class="mt-1 text-sm text-gray-500">TikTok's algorithm predicts which of your products this creator would best promote, based on their audience and content style.</p>
      <ul class="mt-4 space-y-3">
        <% Array(@creator.recommended_products).sort_by { |p| -(p["match_score"] || 0) }.each do |rec| %>
          <% score = rec["match_score"].to_f
             bar_pct = (score * 100).round
             bar_color = score >= 0.8 ? "bg-emerald-500" : score >= 0.6 ? "bg-indigo-500" : "bg-amber-400" %>
          <li class="flex items-center gap-4">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-gray-900"><%= rec["product_name"] %></p>
              <% if rec["reason"].present? %>
                <p class="mt-0.5 text-xs text-gray-500"><%= rec["reason"] %></p>
              <% end %>
              <div class="mt-1.5 h-1.5 w-full rounded-full bg-gray-100">
                <div class="h-1.5 rounded-full <%= bar_color %>" style="width: <%= bar_pct %>%"></div>
              </div>
            </div>
            <span class="shrink-0 text-sm font-semibold text-gray-700"><%= bar_pct %>%</span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-base font-semibold text-gray-900">Outreach history with <%= Current.shop.name %></h2>
    <% if @invites.any? %>
      <table class="mt-4 min-w-full text-sm">
        <thead class="text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="pb-2">Campaign</th>
            <th class="pb-2">Status</th>
            <th class="pb-2">Sent</th>
            <th class="pb-2">Sample</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @invites.each do |invite| %>
            <tr>
              <td class="py-2"><%= invite.campaign.name %></td>
              <td class="py-2 capitalize"><%= invite.status %></td>
              <td class="py-2 text-gray-500"><%= invite.sent_at&.strftime("%b %-d, %Y") || "—" %></td>
              <td class="py-2 text-gray-500">
                <% sample = @samples.find { |s| s.invite_id == invite.id } %>
                <%= sample ? sample.status.capitalize : "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="mt-2 text-sm text-gray-500">You haven't reached out to this creator yet.</p>
    <% end %>
  </div>
</div>
