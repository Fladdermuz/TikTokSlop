<div class="mx-auto max-w-3xl space-y-6">
  <div>
    <%= link_to "← Back to #{@product.name}", shop_product_path(@product), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="mt-2 text-2xl font-semibold text-gray-900"><%= @product.name %> — Knowledge Base</h1>
    <p class="mt-1 text-sm text-gray-500">Rich product info used by the AI message crafter to generate product-specific outreach.</p>
  </div>

  <% if @knowledge.populated? %>
    <div class="space-y-4 rounded-lg border border-gray-200 bg-white p-6">
      <% [ ["Short description", @knowledge.short_description],
           ["Full description", @knowledge.long_description],
           ["Ingredients", @knowledge.ingredients],
           ["Benefits", @knowledge.benefits],
           ["Target audience", @knowledge.target_audience],
           ["Use cases", @knowledge.use_cases],
           ["USP", @knowledge.usp],
           ["Brand", @knowledge.brand_name],
           ["Brand voice", @knowledge.brand_voice],
           ["Size/serving", @knowledge.size_or_serving],
           ["Certifications", Array(@knowledge.certifications).join(", ")],
           ["Warnings", @knowledge.warnings]
         ].each do |label, value| %>
        <% if value.present? %>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wide text-gray-500"><%= label %></dt>
            <dd class="mt-1 whitespace-pre-wrap text-sm text-gray-800"><%= value %></dd>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
      <p class="text-sm text-gray-500">No product knowledge entered yet. The AI crafter works better with detailed product info.</p>
    </div>
  <% end %>

  <% if policy_for(@product).update? %>
    <%= link_to "Edit knowledge", edit_shop_product_knowledge_path(@product), class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
  <% end %>
</div>
