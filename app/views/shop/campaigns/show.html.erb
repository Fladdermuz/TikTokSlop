<div class="space-y-6">
  <div>
    <%= link_to "← Back to campaigns", shop_campaigns_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-semibold text-gray-900"><%= @campaign.name %></h1>
          <% badge_class = { "draft" => "bg-gray-100 text-gray-700", "active" => "bg-emerald-100 text-emerald-700", "paused" => "bg-amber-100 text-amber-700", "ended" => "bg-gray-200 text-gray-500" }[@campaign.status] %>
          <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= badge_class %>"><%= @campaign.status %></span>
        </div>
        <p class="mt-1 text-sm text-gray-500">Product: <strong><%= @campaign.product.name %></strong> · Commission: <%= @campaign.commission_rate ? number_to_percentage(@campaign.commission_rate * 100, precision: 1) : "—" %> · Sample: <%= @campaign.sample_offer? ? "Yes" : "No" %></p>
      </div>

      <div class="flex items-center gap-2">
        <% if policy_for(Invite).create? %>
          <%= link_to "Invite creators", shop_creators_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500",
                title: "Select creators and use the bulk invite flow to add them to a campaign" %>
        <% end %>
        <% if policy_for(@campaign).update? && !@campaign.ended? %>
          <%= link_to "Edit", edit_shop_campaign_path(@campaign), class: "rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        <% end %>
        <%= render "status_actions", campaign: @campaign %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 sm:grid-cols-5">
    <% %i[total pending sent accepted failed].each do |k| %>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <div class="text-xs uppercase tracking-wide text-gray-500"><%= k %></div>
        <div class="mt-1 text-xl font-semibold text-gray-900"><%= @invite_counts[k] %></div>
      </div>
    <% end %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-base font-semibold text-gray-900">Message template</h2>
    <% if @campaign.message_template.present? %>
      <pre class="mt-3 whitespace-pre-wrap rounded-md bg-gray-50 p-4 font-mono text-sm text-gray-800"><%= @campaign.message_template %></pre>
      <% unknown = Messaging::TemplateRenderer.unknown_variables_in(@campaign.message_template) %>
      <% if unknown.any? %>
        <p class="mt-2 text-sm text-amber-700">Unknown variables in template: <%= unknown.map { |v| "{{#{v}}}" }.join(", ") %></p>
      <% end %>
    <% else %>
      <p class="mt-2 text-sm text-gray-500 italic">No message template set.</p>
    <% end %>
  </div>

  <% if @campaign.notes.present? %>
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Notes</h2>
      <p class="mt-2 text-sm whitespace-pre-wrap text-gray-700"><%= @campaign.notes %></p>
    </div>
  <% end %>
</div>
