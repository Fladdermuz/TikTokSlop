<%= form_with model: campaign, url: (campaign.persisted? ? shop_campaign_path(campaign) : shop_campaigns_path), class: "space-y-6 rounded-lg border border-gray-200 bg-white p-6" do |f| %>
  <% if campaign.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      <%= campaign.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <% editable = local_assigns[:editable_fields] || %w[name product_id commission_rate sample_offer message_template notes mode] %>

  <div>
    <%= f.label :name, "Campaign name", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, required: true, disabled: !editable.include?("name"),
          class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 disabled:bg-gray-50 disabled:text-gray-500" %>
  </div>

  <div>
    <%= f.label :product_id, "Product", class: "block text-sm font-medium text-gray-700" %>
    <% products = Current.shop.products.active.order(:name) %>
    <% if products.any? %>
      <%= f.collection_select :product_id, products, :id, :display_label,
            { prompt: "Pick a product" },
            { class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 disabled:bg-gray-50 disabled:text-gray-500",
              disabled: !editable.include?("product_id") } %>
    <% else %>
      <p class="mt-1 text-sm text-amber-700">
        You don't have any active products yet. <%= link_to "Add one →", new_shop_product_path, class: "underline" %>
      </p>
    <% end %>
  </div>

  <div>
    <%= f.label :mode, "Collaboration mode", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-2 grid grid-cols-2 gap-3">
      <label class="flex cursor-pointer items-start gap-3 rounded-md border border-gray-200 p-3 hover:bg-gray-50 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
        <%= f.radio_button :mode, "target", disabled: !editable.include?("mode"), class: "mt-0.5" %>
        <div>
          <div class="text-sm font-medium text-gray-900">Target</div>
          <div class="text-xs text-gray-500">Private invite-only. You pick specific creators and send them individual collaboration offers.</div>
        </div>
      </label>
      <label class="flex cursor-pointer items-start gap-3 rounded-md border border-gray-200 p-3 hover:bg-gray-50 has-[:checked]:border-indigo-500 has-[:checked]:bg-indigo-50">
        <%= f.radio_button :mode, "open", disabled: !editable.include?("mode"), class: "mt-0.5" %>
        <div>
          <div class="text-sm font-medium text-gray-900">Open</div>
          <div class="text-xs text-gray-500">Listed in Creator Marketplace. Any eligible creator can join at the set commission rate.</div>
        </div>
      </label>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :commission_rate, "Commission (0.0–1.0)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :commission_rate, step: 0.01, min: 0, max: 1, disabled: !editable.include?("commission_rate"),
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 disabled:bg-gray-50 disabled:text-gray-500" %>
      <p class="mt-1 text-xs text-gray-500">e.g. 0.15 = 15%</p>
    </div>
    <div class="flex items-center">
      <div class="mt-5 flex items-center gap-2">
        <%= f.check_box :sample_offer, disabled: !editable.include?("sample_offer"),
              class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" %>
        <%= f.label :sample_offer, "Offer free product sample", class: "text-sm text-gray-700" %>
      </div>
    </div>
  </div>

  <div data-controller="moderation"
       data-moderation-url-value="<%= shop_moderation_preview_path %>"
       data-generate-url="<%= shop_message_generation_path %>"
       data-campaign-id="<%= campaign.persisted? ? campaign.id : '' %>">
    <div class="flex items-center justify-between">
      <%= f.label :message_template, "Message template", class: "block text-sm font-medium text-gray-700" %>
      <% if editable.include?("message_template") %>
        <div class="flex gap-2">
          <button type="button"
                  data-action="moderation#generateFromProduct"
                  class="rounded-md border border-emerald-300 bg-white px-2 py-1 text-xs font-medium text-emerald-700 hover:bg-emerald-50">
            Generate from product
          </button>
          <button type="button"
                  data-action="moderation#runAiCheck"
                  class="rounded-md border border-indigo-300 bg-white px-2 py-1 text-xs font-medium text-indigo-700 hover:bg-indigo-50">
            Run AI moderation check
          </button>
        </div>
      <% end %>
    </div>
    <%= f.text_area :message_template, rows: 8, disabled: !editable.include?("message_template"),
          data: { moderation_target: "textarea", action: "input->moderation#onInput" },
          placeholder: "Hey {{creator.handle}}! Love your {{creator.top_category}} content...",
          class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 disabled:bg-gray-50 disabled:text-gray-500" %>
    <div class="mt-2 text-xs text-gray-500">
      <span class="font-medium">Available variables:</span>
      <% Messaging::TemplateRenderer.allowed_keys.each do |key| %>
        <code class="ml-1 rounded bg-gray-100 px-1.5 py-0.5 text-gray-700"><%= "{{#{key}}}" %></code>
      <% end %>
    </div>
    <div data-moderation-target="output" class="mt-3"></div>
  </div>

  <div class="rounded-md border border-amber-100 bg-amber-50 p-4">
    <div class="flex items-start gap-3">
      <%= f.check_box :ab_test_enabled, disabled: !editable.include?("ab_test_enabled"),
            class: "mt-1 rounded border-gray-300 text-amber-600" %>
      <div class="flex-1">
        <%= f.label :ab_test_enabled, "Enable commission A/B test", class: "block text-sm font-medium text-amber-900" %>
        <p class="mt-0.5 text-xs text-amber-800">Split creators into two cohorts at different commission rates to measure the impact on acceptance and conversion.</p>
        <div class="mt-3 grid grid-cols-2 gap-3">
          <div>
            <%= f.label :commission_rate_b, "Cohort B rate (0.0–1.0)", class: "block text-xs font-medium text-amber-900" %>
            <%= f.number_field :commission_rate_b, step: 0.01, min: 0, max: 1, disabled: !editable.include?("commission_rate_b"),
                  placeholder: "0.20",
                  class: "mt-1 block w-full rounded-md border border-amber-200 px-2 py-1 text-sm disabled:bg-gray-50" %>
          </div>
          <div>
            <%= f.label :cohort_b_split_pct, "Cohort B split (%)", class: "block text-xs font-medium text-amber-900" %>
            <%= f.number_field :cohort_b_split_pct, min: 0, max: 100, step: 1, disabled: !editable.include?("cohort_b_split_pct"),
                  placeholder: "50",
                  class: "mt-1 block w-full rounded-md border border-amber-200 px-2 py-1 text-sm disabled:bg-gray-50" %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if campaign.sample_offer? %>
    <div class="rounded-md border border-indigo-100 bg-indigo-50 p-4">
      <h3 class="text-sm font-semibold text-indigo-900">Sample rules</h3>
      <p class="mt-0.5 text-xs text-indigo-800">Controls how creators request samples in this campaign. For open-mode campaigns these are pushed to TikTok via the Edit Open Collaboration Sample Rule API.</p>
      <div class="mt-3 grid grid-cols-3 gap-3">
        <div>
          <%= f.label :max_samples_per_creator, "Max samples per creator", class: "block text-xs font-medium text-indigo-900" %>
          <%= f.number_field :max_samples_per_creator, min: 1, disabled: !editable.include?("max_samples_per_creator"),
                placeholder: "1",
                class: "mt-1 block w-full rounded-md border border-indigo-200 px-2 py-1 text-sm disabled:bg-gray-50" %>
        </div>
        <div>
          <%= f.label :sample_valid_days, "Validity window (days)", class: "block text-xs font-medium text-indigo-900" %>
          <%= f.number_field :sample_valid_days, min: 1, disabled: !editable.include?("sample_valid_days"),
                placeholder: "30",
                class: "mt-1 block w-full rounded-md border border-indigo-200 px-2 py-1 text-sm disabled:bg-gray-50" %>
        </div>
        <div>
          <%= f.label :sample_min_follower_threshold, "Min creator followers", class: "block text-xs font-medium text-indigo-900" %>
          <%= f.number_field :sample_min_follower_threshold, min: 0, step: 1000, disabled: !editable.include?("sample_min_follower_threshold"),
                placeholder: "10000",
                class: "mt-1 block w-full rounded-md border border-indigo-200 px-2 py-1 text-sm disabled:bg-gray-50" %>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :follow_up_template, "Spark Code follow-up template", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :follow_up_template, rows: 6, disabled: !editable.include?("follow_up_template"),
          placeholder: Sample::DEFAULT_FOLLOW_UP_TEMPLATE.strip,
          class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 disabled:bg-gray-50 disabled:text-gray-500" %>
    <p class="mt-1 text-xs text-gray-500">Sent automatically after a sample is delivered. Leave blank to use the default Spark Code request.</p>
  </div>

  <div>
    <%= f.label :notes, "Internal notes", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, rows: 3, disabled: !editable.include?("notes"),
          class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 disabled:bg-gray-50 disabled:text-gray-500" %>
  </div>

  <div class="flex items-center justify-between border-t border-gray-100 pt-4">
    <%= link_to "Cancel", shop_campaigns_path, class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= f.submit (campaign.persisted? ? "Save changes" : "Create campaign"),
          class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer",
          disabled: products.empty? && !campaign.persisted? %>
  </div>
<% end %>
