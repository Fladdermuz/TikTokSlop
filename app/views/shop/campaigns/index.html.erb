<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Campaigns</h1>
      <p class="mt-1 text-sm text-gray-500">Affiliate campaigns managed from <%= Current.shop.name %>.</p>
    </div>
    <% if policy_for(Campaign).create? %>
      <%= link_to "New campaign", new_shop_campaign_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    <% end %>
  </div>

  <% if @campaigns.any? %>
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Product</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3 text-right">Commission</th>
            <th class="px-4 py-3 text-right">Invites sent</th>
            <th class="px-4 py-3 text-right">Accepted</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @campaigns.each do |c| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <%= link_to c.name, shop_campaign_path(c), class: "font-medium text-gray-900 hover:text-indigo-600" %>
              </td>
              <td class="px-4 py-3 text-gray-700"><%= c.product.name %></td>
              <td class="px-4 py-3">
                <% badge_class = { "draft" => "bg-gray-100 text-gray-700", "active" => "bg-emerald-100 text-emerald-700", "paused" => "bg-amber-100 text-amber-700", "ended" => "bg-gray-200 text-gray-500" }[c.status] %>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= badge_class %>"><%= c.status %></span>
              </td>
              <td class="px-4 py-3 text-right tabular-nums"><%= c.commission_rate ? number_to_percentage(c.commission_rate * 100, precision: 1) : "—" %></td>
              <td class="px-4 py-3 text-right tabular-nums"><%= c.sent_invite_count %></td>
              <td class="px-4 py-3 text-right tabular-nums"><%= c.accepted_invite_count %></td>
              <td class="px-4 py-3 text-right">
                <%= link_to "View", shop_campaign_path(c), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
      <p class="text-sm text-gray-500">No campaigns yet.</p>
      <% if policy_for(Campaign).create? %>
        <%= link_to "Create your first campaign", new_shop_campaign_path, class: "mt-4 inline-block rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
      <% end %>
    </div>
  <% end %>
</div>
