<div class="mx-auto max-w-2xl space-y-6">
  <div>
    <%= link_to "← Back", shop_campaign_path(@campaign), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="mt-2 text-2xl font-semibold text-gray-900">Edit <%= @campaign.name %></h1>
    <% if @campaign.status != "draft" %>
      <p class="mt-1 text-sm text-amber-700">This campaign is <%= @campaign.status %> — only the message template and notes can be edited.</p>
    <% end %>
  </div>
  <%= render "form", campaign: @campaign, editable_fields: @editable_fields %>
</div>
