<div class="mx-auto max-w-3xl space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Team members</h1>
      <p class="mt-1 text-sm text-gray-500">People who can access <%= Current.shop.name %>.</p>
    </div>
    <% if policy_for(Membership).create? %>
      <%= link_to "Add member", new_shop_member_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
        <tr>
          <th class="px-4 py-3">User</th>
          <th class="px-4 py-3">Role</th>
          <th class="px-4 py-3">Joined</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @memberships.each do |m| %>
          <tr>
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900"><%= m.user.display_name %></div>
              <div class="text-xs text-gray-500"><%= m.user.email_address %></div>
            </td>
            <td class="px-4 py-3">
              <% role_colors = { "owner" => "bg-purple-100 text-purple-700", "admin" => "bg-indigo-100 text-indigo-700", "member" => "bg-gray-100 text-gray-700" } %>
              <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= role_colors[m.role] %>"><%= m.role %></span>
            </td>
            <td class="px-4 py-3 text-gray-500"><%= m.joined_at&.strftime("%b %-d, %Y") || "Pending" %></td>
            <td class="px-4 py-3 text-right">
              <% if policy_for(Membership).destroy? && m.user != Current.user %>
                <%= button_to "Remove", shop_member_path(m), method: :delete,
                      form: { data: { turbo_confirm: "Remove #{m.user.display_name} from #{Current.shop.name}?" } },
                      class: "text-xs text-red-600 hover:text-red-500" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
