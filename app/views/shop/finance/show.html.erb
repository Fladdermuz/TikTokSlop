<div class="space-y-6">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Finance</h1>
      <p class="mt-1 text-sm text-gray-500">Settlement overview for the last 30 days.</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Payments",     payments_shop_finance_index_path, class: "rounded-md border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Statements",   statements_shop_finance_index_path, class: "rounded-md border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "Transactions", transactions_shop_finance_index_path, class: "rounded-md border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  </div>

  <% if @tiktok_error %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      TikTok API error: <%= @tiktok_error %>
    </div>
  <% end %>

  <%# Recent Payments %>
  <div class="rounded-lg border border-gray-200 bg-white">
    <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Recent Payments</h2>
      <%= link_to "View all", payments_shop_finance_index_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
    </div>
    <% if @recent_payments.any? %>
      <table class="min-w-full divide-y divide-gray-100 text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-6 py-3">Payment ID</th>
            <th class="px-6 py-3">Amount</th>
            <th class="px-6 py-3">Currency</th>
            <th class="px-6 py-3">Status</th>
            <th class="px-6 py-3">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_payments.each do |p| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 font-mono text-xs text-gray-500"><%= p["payment_id"] || p["id"] || "—" %></td>
              <td class="px-6 py-3 font-medium text-gray-900"><%= number_to_currency(p["amount"].to_f / 100, unit: "") %></td>
              <td class="px-6 py-3 text-gray-700"><%= p["currency"] || "—" %></td>
              <td class="px-6 py-3">
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-emerald-100 text-emerald-700"><%= p["status"] || "—" %></span>
              </td>
              <td class="px-6 py-3 text-gray-500"><%= p["payment_date"] || p["create_time"] || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-8 text-center text-sm text-gray-500">No payments found in the last 30 days.</p>
    <% end %>
  </div>

  <%# Recent Statements %>
  <div class="rounded-lg border border-gray-200 bg-white">
    <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
      <h2 class="text-base font-semibold text-gray-900">Recent Statements</h2>
      <%= link_to "View all", statements_shop_finance_index_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
    </div>
    <% if @recent_statements.any? %>
      <table class="min-w-full divide-y divide-gray-100 text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-6 py-3">Statement ID</th>
            <th class="px-6 py-3">Statement Date</th>
            <th class="px-6 py-3">Total Amount</th>
            <th class="px-6 py-3">Currency</th>
            <th class="px-6 py-3">Payment Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @recent_statements.each do |s| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 font-mono text-xs text-gray-500"><%= s["statement_id"] || s["id"] || "—" %></td>
              <td class="px-6 py-3 text-gray-700"><%= s["statement_date"] || s["date"] || "—" %></td>
              <td class="px-6 py-3 font-medium text-gray-900"><%= number_to_currency(s["total_amount"].to_f / 100, unit: "") %></td>
              <td class="px-6 py-3 text-gray-700"><%= s["currency"] || "—" %></td>
              <td class="px-6 py-3">
                <% status_colors = { "PAID" => "bg-emerald-100 text-emerald-700", "PENDING" => "bg-amber-100 text-amber-700", "FAILED" => "bg-red-100 text-red-700" } %>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= status_colors[s["payment_status"]] || 'bg-gray-100 text-gray-600' %>">
                  <%= s["payment_status"] || "—" %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-6 py-8 text-center text-sm text-gray-500">No statements found in the last 30 days.</p>
    <% end %>
  </div>
</div>
