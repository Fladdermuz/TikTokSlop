<div class="space-y-6">
  <div>
    <%= link_to "← Finance overview", shop_finance_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Transactions</h1>
    <p class="mt-1 text-sm text-gray-500">Order, statement, and unsettled transaction records (US &amp; UK only).</p>
  </div>

  <%# Mode tabs %>
  <div class="flex gap-3">
    <%= link_to "By Order",       transactions_shop_finance_index_path(mode: "order"),
          class: "rounded-md px-3 py-1.5 text-sm #{@mode == 'order' ? 'bg-indigo-100 text-indigo-700 font-medium' : 'text-gray-600 hover:bg-gray-100'}" %>
    <%= link_to "By Statement",   transactions_shop_finance_index_path(mode: "statement"),
          class: "rounded-md px-3 py-1.5 text-sm #{@mode == 'statement' ? 'bg-indigo-100 text-indigo-700 font-medium' : 'text-gray-600 hover:bg-gray-100'}" %>
    <%= link_to "Unsettled",      transactions_shop_finance_index_path(mode: "unsettled"),
          class: "rounded-md px-3 py-1.5 text-sm #{@mode == 'unsettled' ? 'bg-indigo-100 text-indigo-700 font-medium' : 'text-gray-600 hover:bg-gray-100'}" %>
  </div>

  <%# Contextual filters %>
  <% if @mode == "order" %>
    <%= form_with url: transactions_shop_finance_index_path, method: :get, class: "flex flex-wrap items-end gap-3" do |f| %>
      <%= f.hidden_field :mode, value: "order" %>
      <div>
        <%= f.label :start_date, "From", class: "block text-xs font-medium text-gray-700" %>
        <%= f.date_field :start_date, value: @start_date, class: "mt-1 block rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <div>
        <%= f.label :end_date, "To", class: "block text-xs font-medium text-gray-700" %>
        <%= f.date_field :end_date, value: @end_date, class: "mt-1 block rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <%= f.submit "Filter", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
    <% end %>
  <% elsif @mode == "statement" %>
    <%= form_with url: transactions_shop_finance_index_path, method: :get, class: "flex flex-wrap items-end gap-3" do |f| %>
      <%= f.hidden_field :mode, value: "statement" %>
      <div class="flex-1 min-w-64">
        <%= f.label :statement_id, "Statement ID", class: "block text-xs font-medium text-gray-700" %>
        <%= f.text_field :statement_id, value: @statement_id, placeholder: "Enter statement ID…",
              class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
      </div>
      <%= f.submit "Lookup", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
    <% end %>
    <% if @statement_id.blank? %>
      <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
        <p class="text-sm text-gray-500">Enter a statement ID above, or go to <strong>Statements</strong> and click "View" on a row.</p>
      </div>
    <% end %>
  <% elsif @mode == "unsettled" %>
    <div class="rounded-lg border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      Showing unsettled transactions. Only covers activity after January 1, 2025.
    </div>
  <% end %>

  <% if @tiktok_error %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      TikTok API error: <%= @tiktok_error %>
    </div>
  <% end %>

  <% if @transactions.any? %>
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Transaction ID</th>
            <th class="px-4 py-3">Order ID</th>
            <th class="px-4 py-3">Type</th>
            <th class="px-4 py-3">Amount</th>
            <th class="px-4 py-3">Currency</th>
            <th class="px-4 py-3">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @transactions.each do |t| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= t["transaction_id"] || t["id"] || "—" %></td>
              <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= t["order_id"] || "—" %></td>
              <td class="px-4 py-3 text-gray-700"><%= t["transaction_type"] || t["type"] || "—" %></td>
              <td class="px-4 py-3 font-medium text-gray-900"><%= number_to_currency(t["amount"].to_f / 100, unit: "") %></td>
              <td class="px-4 py-3 text-gray-700"><%= t["currency"] || "—" %></td>
              <td class="px-4 py-3 text-gray-500"><%= t["transaction_date"] || t["create_time"] || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @next_page_token.present? %>
      <div class="flex justify-center">
        <%= link_to "Load more", transactions_shop_finance_index_path(mode: @mode, start_date: @start_date, end_date: @end_date, statement_id: @statement_id, page_token: @next_page_token),
              class: "rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      </div>
    <% end %>
  <% elsif @tiktok_error.blank? && !(@mode == "statement" && @statement_id.blank?) %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
      <p class="text-sm text-gray-500">No transactions found.</p>
    </div>
  <% end %>
</div>
