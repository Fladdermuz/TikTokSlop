<div class="space-y-6">
  <div>
    <%= link_to "← Finance overview", shop_finance_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Payments</h1>
      <p class="mt-1 text-sm text-gray-500">Payment records from TikTok Shop settlements.</p>
    </div>
  </div>

  <%# Date range filter %>
  <%= form_with url: payments_shop_finance_index_path, method: :get, class: "flex flex-wrap items-end gap-3" do |f| %>
    <div>
      <%= f.label :start_date, "From", class: "block text-xs font-medium text-gray-700" %>
      <%= f.date_field :start_date, value: @start_date, class: "mt-1 block rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :end_date, "To", class: "block text-xs font-medium text-gray-700" %>
      <%= f.date_field :end_date, value: @end_date, class: "mt-1 block rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <%= f.submit "Filter", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  <% end %>

  <% if @tiktok_error %>
    <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
      TikTok API error: <%= @tiktok_error %>
    </div>
  <% end %>

  <% if @payments.any? %>
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase tracking-wide text-gray-500">
          <tr>
            <th class="px-4 py-3">Payment ID</th>
            <th class="px-4 py-3">Amount</th>
            <th class="px-4 py-3">Currency</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Payment Date</th>
            <th class="px-4 py-3">Statement ID</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @payments.each do |p| %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-mono text-xs text-gray-500"><%= p["payment_id"] || p["id"] || "—" %></td>
              <td class="px-4 py-3 font-medium text-gray-900"><%= number_to_currency(p["amount"].to_f / 100, unit: "") %></td>
              <td class="px-4 py-3 text-gray-700"><%= p["currency"] || "—" %></td>
              <td class="px-4 py-3">
                <% colors = { "PAID" => "bg-emerald-100 text-emerald-700", "PENDING" => "bg-amber-100 text-amber-700", "FAILED" => "bg-red-100 text-red-700" } %>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= colors[p["status"]] || 'bg-gray-100 text-gray-600' %>">
                  <%= p["status"] || "—" %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-500"><%= p["payment_date"] || p["create_time"] || "—" %></td>
              <td class="px-4 py-3 font-mono text-xs text-gray-400"><%= p["statement_id"] || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @next_page_token.present? %>
      <div class="flex justify-center">
        <%= link_to "Load more", payments_shop_finance_index_path(start_date: @start_date, end_date: @end_date, page_token: @next_page_token),
              class: "rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      </div>
    <% end %>
  <% else %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
      <p class="text-sm text-gray-500">No payments found for the selected date range.</p>
    </div>
  <% end %>
</div>
