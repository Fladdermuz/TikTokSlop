<div id="generation_result" class="space-y-3">
  <div class="rounded-md border border-indigo-200 bg-indigo-50 p-4">
    <div class="flex items-center justify-between">
      <span class="text-xs font-medium uppercase tracking-wide text-indigo-700">AI-generated template</span>
      <span class="text-xs text-indigo-500">model: <%= result.model %> · retries: <%= result.retries_used %></span>
    </div>
    <pre class="mt-2 whitespace-pre-wrap text-sm text-indigo-900"><%= result.text %></pre>
    <button type="button"
            data-action="moderation#applyGeneration"
            data-text="<%= result.text %>"
            class="mt-3 rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-500">
      Use this template
    </button>
  </div>

  <% unless result.moderation_result.low? %>
    <%= render "shop/moderation_previews/result", result: result.moderation_result %>
  <% end %>
</div>
