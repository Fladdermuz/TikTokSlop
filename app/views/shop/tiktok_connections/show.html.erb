<div class="mx-auto max-w-3xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">TikTok Shop connection</h1>
    <p class="mt-1 text-sm text-gray-500">Authorize Tikedon to act on behalf of <%= Current.shop.name %>'s TikTok seller account.</p>
  </div>

  <% if @token.present? %>
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
            <h2 class="text-base font-semibold text-emerald-900">Connected</h2>
          </div>
          <dl class="mt-3 grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
            <dt class="text-emerald-800">Shop name</dt>
            <dd class="text-emerald-900 font-medium"><%= @token.shop_name || "—" %></dd>

            <dt class="text-emerald-800">Seller</dt>
            <dd class="text-emerald-900 font-medium"><%= @token.seller_name || "—" %></dd>

            <dt class="text-emerald-800">External shop ID</dt>
            <dd class="text-emerald-900 font-mono text-xs"><%= @token.external_shop_id %></dd>

            <dt class="text-emerald-800">Access token expires</dt>
            <dd class="text-emerald-900">
              <%= @token.access_expires_at.in_time_zone(Current.shop.timezone).strftime("%b %-d, %Y %-l:%M %p %Z") %>
              <% if @token.access_expired? %>
                <span class="ml-1 text-amber-700">(expired — will auto-refresh)</span>
              <% end %>
            </dd>

            <dt class="text-emerald-800">Refresh token expires</dt>
            <dd class="text-emerald-900">
              <%= @token.refresh_expires_at.in_time_zone(Current.shop.timezone).strftime("%b %-d, %Y") %>
            </dd>
          </dl>
        </div>
      </div>

      <% if policy_for(TiktokToken).destroy? %>
        <div class="mt-6 border-t border-emerald-200 pt-4">
          <%= button_to "Disconnect", shop_tiktok_connection_path,
                method: :delete,
                form: { data: { turbo_confirm: "Are you sure? You'll need to re-authorize before sending any more invites." } },
                class: "rounded-md border border-red-300 bg-white px-3 py-2 text-sm font-medium text-red-700 hover:bg-red-50" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-gray-200 bg-white p-8">
      <h2 class="text-base font-semibold text-gray-900">Not connected</h2>
      <p class="mt-2 text-sm text-gray-600">Click below to authorize Tikedon with your TikTok Shop seller account. You'll be redirected to TikTok to confirm.</p>

      <% if policy_for(TiktokToken).create? %>
        <%= button_to shop_tiktok_connection_path, method: :post, class: "mt-6 inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" do %>
          Connect TikTok Shop
        <% end %>
      <% else %>
        <p class="mt-4 text-sm text-amber-700">Only shop admins can connect TikTok. Ask the shop owner.</p>
      <% end %>
    </div>
  <% end %>

  <div class="rounded-lg border border-gray-200 bg-gray-50 p-6 text-sm text-gray-600">
    <h3 class="font-semibold text-gray-900">What Tikedon does with this connection</h3>
    <ul class="mt-2 list-disc space-y-1 pl-5">
      <li>Search affiliate creators by GMV, category, follower count, and engagement.</li>
      <li>Send targeted collaboration invites to chosen creators on your behalf.</li>
      <li>Create and track sample fulfillment requests.</li>
      <li>Refresh tokens automatically before they expire.</li>
    </ul>
    <p class="mt-3">All access tokens are encrypted at rest. You can disconnect at any time.</p>
  </div>
</div>
