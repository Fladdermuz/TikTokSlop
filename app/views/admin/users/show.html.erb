<div class="mx-auto max-w-3xl space-y-6">
  <div>
    <%= link_to "← All users", admin_users_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="mt-2 text-2xl font-semibold text-gray-900"><%= @user.display_name %></h1>
    <p class="mt-1 text-sm text-gray-500"><%= @user.email_address %><%= " · Platform admin" if @user.platform_admin? %></p>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-base font-semibold text-gray-900">Shop memberships</h2>
    <% if @memberships.any? %>
      <ul class="mt-3 divide-y divide-gray-100 text-sm">
        <% @memberships.each do |m| %>
          <li class="flex items-center justify-between py-2">
            <%= link_to m.shop.name, admin_shop_path(m.shop), class: "text-gray-900 hover:text-indigo-600" %>
            <span class="rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-700"><%= m.role %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mt-2 text-sm text-gray-500">Not a member of any shops.</p>
    <% end %>
  </div>
</div>
