<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Platform Admin</h1>
    <p class="mt-1 text-sm text-gray-500">System-wide overview.</p>
  </div>

  <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
    <% @stats.each do |label, value| %>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <div class="text-xs font-medium uppercase tracking-wide text-gray-500"><%= label.to_s.tr("_", " ") %></div>
        <div class="mt-1 text-lg font-semibold text-gray-900">
          <%= label.to_s.include?("cost") ? "$#{format('%.2f', value / 100.0)}" : value %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Recent shops</h2>
      <ul class="mt-3 divide-y divide-gray-100 text-sm">
        <% @recent_shops.each do |shop| %>
          <li class="flex items-center justify-between py-2">
            <%= link_to shop.name, admin_shop_path(shop), class: "text-gray-900 hover:text-indigo-600" %>
            <span class="text-xs text-gray-500"><%= shop.created_at.strftime("%b %-d") %> · <%= shop.memberships.count %> members</span>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="rounded-lg border border-gray-200 bg-white p-6">
      <h2 class="text-base font-semibold text-gray-900">Recent users</h2>
      <ul class="mt-3 divide-y divide-gray-100 text-sm">
        <% @recent_users.each do |user| %>
          <li class="flex items-center justify-between py-2">
            <%= link_to user.display_name, admin_user_path(user), class: "text-gray-900 hover:text-indigo-600" %>
            <span class="text-xs text-gray-500"><%= user.email_address %><%= " · admin" if user.platform_admin? %></span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
