<div class="mx-auto max-w-3xl space-y-6">
  <div>
    <%= link_to "← All shops", admin_shops_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <h1 class="mt-2 text-2xl font-semibold text-gray-900"><%= @shop.name %></h1>
    <p class="mt-1 text-sm text-gray-500">Slug: <%= @shop.slug %> · Status: <%= @shop.status %> · Plan: <%= @shop.plan %></p>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs font-medium uppercase tracking-wide text-gray-500">TikTok</div>
      <div class="mt-1 text-sm"><%= @token ? "Connected (#{@token.seller_name || @token.external_shop_id})" : "Not connected" %></div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Invites</div>
      <div class="mt-1 text-lg font-semibold"><%= @invite_count %></div>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-4">
      <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Samples</div>
      <div class="mt-1 text-lg font-semibold"><%= @sample_count %></div>
    </div>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-base font-semibold text-gray-900">Members</h2>
    <ul class="mt-3 divide-y divide-gray-100 text-sm">
      <% @memberships.each do |m| %>
        <li class="flex items-center justify-between py-2">
          <%= link_to m.user.display_name, admin_user_path(m.user), class: "text-gray-900 hover:text-indigo-600" %>
          <span class="rounded-full px-2 py-0.5 text-xs font-medium bg-gray-100 text-gray-700"><%= m.role %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>
