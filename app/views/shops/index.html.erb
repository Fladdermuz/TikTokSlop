<div class="mx-auto max-w-3xl">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-gray-900">Your shops</h1>
      <p class="mt-1 text-sm text-gray-500">Switch between shops or create a new one.</p>
    </div>
    <%= link_to "New shop", new_shop_path, class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
  </div>

  <% if @shops.any? %>
    <ul class="divide-y divide-gray-200 overflow-hidden rounded-lg border border-gray-200 bg-white">
      <% @shops.each do |shop| %>
        <li class="flex items-center justify-between px-4 py-4">
          <div>
            <div class="text-sm font-medium text-gray-900"><%= shop.name %></div>
            <div class="text-xs text-gray-500"><%= shop.slug %> · <%= shop.plan %> · <%= shop.status %></div>
          </div>
          <%= button_to "Open", switch_shop_path(shop), method: :post, class: "rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center">
      <p class="text-sm text-gray-500">You don't belong to any shops yet.</p>
      <%= link_to "Create your first shop", new_shop_path, class: "mt-4 inline-block rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
    </div>
  <% end %>
</div>
